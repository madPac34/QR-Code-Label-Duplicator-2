[Unit]
Description=QR Label Clone Service
After=network.target

[Service]
Type=simple
WorkingDirectory=/opt/labelclone
ExecStart=/opt/labelclone/.venv/bin/python /opt/labelclone/labelclone.py
Restart=always
RestartSec=2
User=root
Group=root
Environment=PYTHONUNBUFFERED=1

[Install]
WantedBy=multi-user.target
